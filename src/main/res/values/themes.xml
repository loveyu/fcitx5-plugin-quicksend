<?xml version="1.0" encoding="utf-8"?>
<!--
  设置页主题：去掉系统标题栏（windowActionBar=false / windowNoTitle=true），
  仅保留布局自绘的标题与返回按钮，消除“双标题”。

  基类使用 DeviceDefault.Light：API 24-28 无系统深色模式开关，固定浅色即可；
  API 29+ 由 values-v29/themes.xml 覆盖为 DeviceDefault.DayNight，
  自动跟随系统深色模式，无需 AppCompat 依赖。
-->
<resources>

    <style name="Theme.QuickSend" parent="@android:style/Theme.DeviceDefault.Light">
        <item name="android:windowActionBar">false</item>
        <item name="android:windowNoTitle">true</item>
    </style>

</resources>
