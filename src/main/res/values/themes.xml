<?xml version="1.0" encoding="utf-8"?>
<!--
  设置页主题：去掉系统标题栏（windowActionBar=false / windowNoTitle=true），
  仅保留布局自绘的标题与返回按钮，消除“双标题”。
  其余沿用 DeviceDefault.Light 观感。
-->
<resources>

    <style name="Theme.QuickSend" parent="@android:style/Theme.DeviceDefault.Light">
        <item name="android:windowActionBar">false</item>
        <item name="android:windowNoTitle">true</item>
    </style>

</resources>
